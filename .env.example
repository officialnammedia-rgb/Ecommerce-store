# Database (SQLite for local dev; switch provider in prisma/schema.prisma for Postgres)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="change-me-in-prod"
NEXTAUTH_URL="http://localhost:3000"

# Stabilizes Next.js server-action IDs across dev restarts so the browser tab
# doesn't get "Invalid Server Actions request" after hot-reload. Use a long random
# string in production too.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="change-me-32-byte-base64-or-random-string"

# Razorpay (added in final phase)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Email (optional; logs to console if empty)
RESEND_API_KEY=""
EMAIL_FROM="Store <noreply@example.com>"

# Store settings
STORE_NAME="Aurelia"
STORE_CURRENCY="INR"
STORE_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_STORE_NAME="Aurelia"
