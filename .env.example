# Database (SQLite for local dev; switch provider in prisma/schema.prisma for Postgres)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="change-me-in-prod"
NEXTAUTH_URL="http://localhost:3000"

# Stabilizes Next.js server-action IDs across dev restarts so the browser tab
# doesn't get "Invalid Server Actions request" after hot-reload. Use a long random
# string in production too.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="change-me-32-byte-base64-or-random-string"

# Razorpay — needed to accept online card/UPI payments. Copy from
# https://dashboard.razorpay.com → Account & Settings → API Keys.
# Leave blank to use Cash on Delivery only.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Webhook secret from Dashboard → Settings → Webhooks. Used to verify that
# payment.captured events really came from Razorpay.
RAZORPAY_WEBHOOK_SECRET=""

# Email (optional; logs to console if empty)
RESEND_API_KEY=""
EMAIL_FROM="Ascendyl <Ascendyl204@gmail.com>"

# Cloudinary — image uploads from /admin/products/*.
# Either paste the full CLOUDINARY_URL from your dashboard (simplest) OR set the
# three individual vars. If none are set, uploads fall back to ./public/uploads
# which does NOT persist on Vercel.
CLOUDINARY_URL=""
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
# Optional folder inside your Cloudinary account. Defaults to "ascendyl/products".
CLOUDINARY_FOLDER=""

# Store settings
STORE_NAME="Ascendyl"
STORE_CURRENCY="INR"
# Public, absolute origin used by metadata/sitemap/robots/OG. Set this in Vercel
# to the production domain, e.g. https://ascendyl.in. Either env var works
# (NEXT_PUBLIC_ wins because it's available client-side too).
STORE_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_STORE_NAME="Ascendyl"
STORE_LEGAL_NAME="Ascendyl Solutions Private Limited"
STORE_ADDRESS="Office No 206, Plot No 1, 2nd Floor, Ambar Tower, Naniwala Bagh, Azadpur, North West Delhi, Delhi - 110033"
SUPPORT_EMAIL="Ascendyl204@gmail.com"
SUPPORT_PHONE="+91 7037638457"

# Google Analytics 4 — paste your Measurement ID (G-XXXXXXX). Leave empty to
# disable analytics entirely. Loads only after the visitor accepts cookies.
NEXT_PUBLIC_GA_ID=""
