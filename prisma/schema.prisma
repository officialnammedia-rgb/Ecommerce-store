// Prisma schema — Aurelia clothing store
// Provider is SQLite for fast local dev. To switch to Postgres for prod:
// 1) change provider to "postgresql"
// 2) update DATABASE_URL
// 3) run a fresh `prisma migrate dev`
// All money fields are stored as INTEGER paise (smallest INR unit).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------- Users / Auth ----------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          String    @default("CUSTOMER") // CUSTOMER | ADMIN | MANAGER
  emailVerified DateTime?
  image         String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses Address[]
  orders    Order[]
  carts     Cart[]
  sessions  Session[]
  accounts  Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Address {
  id         String  @id @default(cuid())
  userId     String?
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String  @default("IN")
  type       String  @default("SHIPPING") // SHIPPING | BILLING
  isDefault  Boolean @default(false)
  // true = shown in the user's address book. Order-snapshot clones set this false
  // so previously-used addresses don't duplicate the book every time.
  savedInBook Boolean @default(true)

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[] @relation("OrderShippingAddress")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------- Analytics ----------------

model PageView {
  id        String   @id @default(cuid())
  path      String
  sessionId String   // anonymous visitor cookie
  userAgent String?
  referer   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([sessionId])
}

// ---------------- Catalog ----------------

model Product {
  id              String  @id @default(cuid())
  slug            String  @unique
  title           String
  description     String?
  vendor          String?
  status          String  @default("DRAFT") // DRAFT | ACTIVE | ARCHIVED
  tags            String? // comma-separated for SQLite simplicity
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  options     ProductOption[]
  variants    ProductVariant[]
  images      ProductImage[]
  collections CollectionProduct[]
}

model ProductOption {
  id        String @id @default(cuid())
  productId String
  name      String // e.g., "Size", "Color"
  position  Int    @default(0)

  product Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  values  ProductOptionValue[]
}

model ProductOptionValue {
  id       String @id @default(cuid())
  optionId String
  value    String // e.g., "M", "Black"

  option ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id              String  @id @default(cuid())
  productId       String
  sku             String  @unique
  // Up to 3 named option values per variant; flat columns keep SQLite simple.
  optionName1     String?
  optionValue1    String?
  optionName2     String?
  optionValue2    String?
  optionName3     String?
  optionValue3    String?
  // Money in paise (INR smallest unit)
  price           Int
  compareAtPrice  Int?
  weightGrams     Int?
  inventoryQty    Int     @default(0)
  lowStockAt      Int     @default(5)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems CartItem[]
  orderItems OrderItem[]
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Collection {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String?
  imageUrl    String?
  isFeatured  Boolean @default(false)
  position    Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products CollectionProduct[]
}

model CollectionProduct {
  collectionId String
  productId    String
  position     Int    @default(0)

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
}

// ---------------- Cart ----------------

model Cart {
  id         String  @id @default(cuid())
  userId     String?
  guestToken String? @unique
  currency   String  @default("INR")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id            String @id @default(cuid())
  cartId        String
  variantId     String
  quantity      Int    @default(1)
  priceSnapshot Int    // paise

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
}

// ---------------- Orders ----------------

model Order {
  id             String  @id @default(cuid())
  orderNumber    String  @unique
  userId         String?
  email          String
  phone          String?
  currency       String  @default("INR")

  // Money totals in paise
  subtotal       Int
  discountTotal  Int     @default(0)
  shippingTotal  Int     @default(0)
  taxTotal       Int     @default(0)
  grandTotal     Int

  status         String  @default("PENDING_PAYMENT") // PENDING_PAYMENT | PAID | FULFILLED | DELIVERED | CANCELLED | REFUNDED
  paymentStatus  String  @default("PENDING")          // PENDING | PAID | FAILED | REFUNDED | PARTIALLY_REFUNDED
  paymentMethod  String? // RAZORPAY | COD | STUB

  shippingAddressId String?
  notes             String?
  couponCode        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User?         @relation(fields: [userId], references: [id])
  shippingAddress Address?      @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id])
  items           OrderItem[]
  payments        Payment[]
  fulfillments    Fulfillment[]
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  variantId       String
  productTitle    String
  variantTitle    String? // composed from option values for snapshot
  sku             String
  unitPrice       Int     // paise
  quantity        Int
  imageUrl        String?

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])
}

model Payment {
  id              String  @id @default(cuid())
  orderId         String
  provider        String  // RAZORPAY | COD | STUB
  providerOrderId String?
  providerPaymentId String?
  amount          Int     // paise
  currency        String  @default("INR")
  status          String  @default("PENDING") // PENDING | SUCCEEDED | FAILED | REFUNDED
  rawPayload      String? // serialized JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Fulfillment {
  id             String  @id @default(cuid())
  orderId        String
  carrier        String?
  trackingNumber String?
  trackingUrl    String?
  status         String  @default("PENDING") // PENDING | SHIPPED | DELIVERED | CANCELLED
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ---------------- Promotions ----------------

model Discount {
  id            String  @id @default(cuid())
  code          String  @unique
  type          String  // PERCENT | FIXED
  value         Int     // percent (1-100) or paise
  minSubtotal   Int     @default(0)
  startsAt      DateTime?
  endsAt        DateTime?
  usageLimit    Int?
  usedCount     Int     @default(0)
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ---------------- Content / Settings ----------------

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  body      String
  isPublished Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomeSection {
  id        String   @id @default(cuid())
  kind      String   // HERO | FEATURED_COLLECTION | BANNER
  title     String?
  subtitle  String?
  imageUrl  String?
  linkUrl   String?
  data      String?  // JSON string for flexible payload
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  key   String @id
  value String
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  String?
  createdAt DateTime @default(now())
}

model Review {
  id            String   @id @default(cuid())
  productId     String
  userId        String
  orderId       String?  // optional — verified-purchase flag
  rating        Int      // 1..5
  title         String?
  body          String
  isApproved    Boolean  @default(true) // simple moderation toggle
  createdAt     DateTime @default(now())

  @@index([productId])
  @@index([userId])
  @@unique([productId, userId]) // one review per user per product
}

model Return {
  id           String       @id @default(cuid())
  orderId      String
  userId       String
  reason       String
  status       String       @default("REQUESTED") // REQUESTED | APPROVED | REJECTED | RECEIVED | REFUNDED
  adminNote    String?
  refundAmount Int?         // paise, decided on approval
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  items        ReturnItem[]

  @@index([orderId])
  @@index([userId])
  @@index([status])
}

model ReturnItem {
  id          String  @id @default(cuid())
  returnId    String
  orderItemId String
  quantity    Int

  return Return @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
}
